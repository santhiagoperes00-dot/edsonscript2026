        print("[EDSON SCRIPT] ESP Nome Ativado")
        -- Lógica de Drawing.new("Text") iria aqui
    else
        print("[EDSON SCRIPT] ESP Nome Desativado")
    end
end)

CreateToggle("EspEsqueleto", "ESP Esqueleto", function(state)
    if state then
        print("[EDSON SCRIPT] ESP Esqueleto Ativado")
        -- Lógica de ligar as joints dos personagens iria aqui
