CreateToggle("AimbotRage", "Aimbot Rage (Puxa Rápido)", function(state)
    if state then
        Toggles.AimbotLegit = false -- Desativa o Legit se o Rage ligar
        print("[EDSON SCRIPT] Aimbot Rage Ativado")
        -- Lógica de CFrame instantâneo (Camera.CFrame = CFrame.new(...)) iria aqui
    else
        print("[EDSON SCRIPT] Aimbot Rage Desativado")
    end
end)

CreateToggle("AimbotLegit", "Aimbot Legit (Smooth/Delay)", function(state)
    if state then
        Toggles.AimbotRage = false -- Desativa o Rage se o Legit ligar
        print("[EDSON SCRIPT] Aimbot Legit Ativado")
        -- Lógica de TweenService na câmera ou Lerp (suavização) iria aqui
    else
        print("[EDSON SCRIPT] Aimbot Legit Desativado")
    end
end)

